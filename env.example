# Copy to .env (gitignored) and fill in. Aegis runs fully offline if these are absent.

# Live provider proof-of-life (gpt-4o-mini). Without it, only the mock adapter works.
OPENAI_API_KEY=

# Optional hosted evidence loop. Without it, Aegis writes local JSONL traces (.aegis/traces/).
BRAINTRUST_API_KEY=

# Optional xAI/Grok adapter (stretch).
XAI_API_KEY=

# Policy mode for the demo: observe | balanced | strict
AEGIS_POLICY_MODE=balanced

# Set to 1 to keep raw content in traces (LOCAL TEST ONLY — never in shared runs).
AEGIS_LOCAL_TEST_MODE=0
